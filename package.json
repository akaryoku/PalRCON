{
  "name": "palrcon",
  "version": "1.0.6",
  "private": true,
  "description": "Local desktop administration console for Palworld dedicated servers",
  "main": "dist-electron/main/index.js",
  "author": "PalRCON",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run typecheck && vite build && tsc -p electron/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:layout": "npm run build && electron scripts/verify-console-layout.cjs",
    "test:watch": "vitest",
    "assets": "node scripts/generate-assets.mjs",
    "metadata": "node scripts/apply-windows-metadata.mjs",
    "checksums": "node scripts/generate-checksums.mjs",
    "package": "npm run assets && npm run build && electron-builder --win --dir && npm run metadata && electron-builder --prepackaged release/win-unpacked --win nsis portable && npm run checksums",
    "start": "electron ."
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2",
    "rcedit": "^5.0.2",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.palrcon.desktop",
    "productName": "PalRCON",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "PalRCON-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "PalRCON-Portable-${version}-${arch}.${ext}"
    }
  }
}
